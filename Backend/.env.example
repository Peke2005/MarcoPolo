# Supabase Postgres connection.
# Supabase Dashboard -> Project Settings -> Database -> Connection string.
# Use pooler if possible. Keep this file as .env locally; do not commit real secrets.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Required for Supabase Postgres SSL.
PGSSLMODE=require

# Change this to a long random secret before sharing the backend.
JWT_SECRET=change-me-long-random-secret

AUTH_STORE=postgres
PORT=3001
